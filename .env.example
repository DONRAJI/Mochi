# 서버 전용 (NEXT_PUBLIC_ 접두사 금지 — 붙이면 브라우저에 평문 노출)
DATABASE_URL=
DIRECT_URL=        # 마이그레이션용 직접 연결 (Supabase 풀러 우회 — schema.prisma의 directUrl)
SESSION_SECRET=
# 외부 API 키 (서버 Route Handler·인제스트 스크립트에서만 사용)
RECIPE_API_KEY=        # 식품안전나라 조리식품 레시피 DB(COOKRCP01) 인증키
NUTRITION_API_KEY=     # data.go.kr 식품영양성분 DB 키
VISION_API_KEY=

# Supabase Storage (식사 사진 — PRD 8-3). 서버 전용, NEXT_PUBLIC_ 금지.
SUPABASE_URL=                  # 프로젝트 URL (https://<ref>.supabase.co)
SUPABASE_SERVICE_ROLE_KEY=     # 서버 전용 시크릿 키(sb_secret_… 또는 service_role). 클라 노출 금지
SUPABASE_STORAGE_BUCKET=       # 비공개 버킷 이름 (image/* 전용)

# 레이트 리밋 공유 스토어 (Upstash Redis REST — 서버리스 멀티 인스턴스에서 유효).
# 없으면 인메모리 폴백(개발·단일 인스턴스). REST라 새 의존성 없음.
UPSTASH_REDIS_REST_URL=        # https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=      # Upstash REST 토큰 (서버 전용, 클라 노출 금지)

# 클라 공개용만 NEXT_PUBLIC_ 사용 (절대 시크릿 X)
NEXT_PUBLIC_APP_URL=http://localhost:3000
