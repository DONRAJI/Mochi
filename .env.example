# 서버 전용 (NEXT_PUBLIC_ 접두사 금지 — 붙이면 브라우저에 평문 노출)
DATABASE_URL=
DIRECT_URL=        # 마이그레이션용 직접 연결 (Supabase 풀러 우회 — schema.prisma의 directUrl)
SESSION_SECRET=
# 외부 API 키 (서버 Route Handler·인제스트 스크립트에서만 사용)
RECIPE_API_KEY=        # 식품안전나라 조리식품 레시피 DB(COOKRCP01) 인증키
NUTRITION_API_KEY=     # data.go.kr 식품영양성분 DB 키
VISION_API_KEY=

# 클라 공개용만 NEXT_PUBLIC_ 사용 (절대 시크릿 X)
NEXT_PUBLIC_APP_URL=http://localhost:3000
